# Copy this file to `.env` before running `pnpm dist` on your Windows PC.
# DO NOT commit `.env` to git.

# The URL of your deployed Flight Hour Tracker dashboard. The Electron
# window loads this URL at startup.
DASHBOARD_URL=https://flight-hour-tracker.replit.app/

# The plaintext password the NSIS installer will prompt for on every PC
# before allowing installation. Keep this secret — anyone who knows it can
# install the app. Choose something memorable but not trivial.
INSTALLER_PASSWORD=changeme

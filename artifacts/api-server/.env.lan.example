# ── Hawk Eye api-server — LAN defaults ─────────────────────────────────
# Copy to artifacts/api-server/.env.production on the host PC and edit.
# These values control the only backend Hawk Eye talks to in LAN mode.

# Internal Postgres for LAN operation. Use a strong password — this is
# the only secret that protects the local DB.
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/hawkeye_internal

# Enforce LAN session token on /api/internal/* data routes. Set to
# `optional` only for first-boot bring-up; flip back to `required` once
# at least one super_admin exists.
HAWK_INTERNAL_SESSION_AUTH=required

# First admin bootstrap token — required for the very first
# `/api/internal/auth/lan/dev-session` call that mints the first
# super_admin. Rotate immediately after first use.
HAWK_LAN_BOOTSTRAP_TOKEN=change-this-bootstrap-token

# Production must be 0. When 1, every internal route accepts requests
# with no LAN session at all, which is only safe on a single-engineer
# dev box.
HAWK_LAN_DEV_NO_AUTH=0

# Port the api-server binds to. All dashboards must use this same port
# in their VITE_INTERNAL_API_URL.
PORT=3847

# Friendly squadron name for this hub PC. first-time-setup.ps1 fills
# this in and uses it as the Windows hostname so the LAN can reach the
# hub at `<SQUADRON_NAME>.local`. Letters / digits / hyphen, 1-15
# chars, no leading or trailing hyphen, not all digits.
SQUADRON_NAME=tigers-hub

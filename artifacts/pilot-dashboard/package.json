{
  "name": "@workspace/pilot-dashboard",
  "version": "1.1.110",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:smoke && npm run test:buttons && npm run test:sortie-smart && npm run test:add-sortie-ui && npm run test:schedule-names && npm run test:monthly-report && npm run test:join-lifecycle && npm run test:fault-injection && npm run test:squadron-merge && npm run test:squadrons-remote && npm run test:lan-user-map && npm run test:admin-audit-lan && npm run test:admin-overview-stats && npm run test:translations && npm run test:lan-read-scope && npm run test:lan-read-scope-routes && npm run test:install-profile-routes && npm run test:peer-tokens-routes && npm run test:peer-tokens-page && npm run test:aggregate-fanout && npm run test:install-profile-bootstrap && npm run test:aggregator-ui && npm run test:ensure-schema && npm run test:legacy-residue && npm run test:calc-snapshot && npm run test:multi-pc-cross && npm run test:multi-pc-real-process && npm run test:sorties-writes-gate",
    "test:install-profile-bootstrap": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/install-profile-bootstrap.test.ts",
    "test:aggregator-ui": "tsx --tsconfig tests/tsconfig.json --import=./tests/asset-loader-register.mjs --test --test-force-exit tests/aggregator-ui.test.ts",
    "test:smoke": "tsx --tsconfig tests/tsconfig.json --import=./tests/asset-loader-register.mjs --test --test-force-exit tests/sidebar-smoke.test.ts",
    "test:buttons": "tsx --tsconfig tests/tsconfig.json --import=./tests/asset-loader-register.mjs --test --test-force-exit tests/button-sweep.test.ts",
    "test:sortie-smart": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/add-sortie-smart.test.ts",
    "test:add-sortie-ui": "tsx --tsconfig tests/tsconfig.json --import=./tests/asset-loader-register.mjs --test --test-force-exit tests/add-sortie-form-availability.test.ts",
    "test:schedule-names": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/schedule-names.test.ts",
    "test:monthly-report": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/monthly-report-forms.test.ts",
    "test:join-lifecycle": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/join-lifecycle.test.ts",
    "test:fault-injection": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/fault-injection.test.ts",
    "test:squadron-merge": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/squadron-defaults-merge.test.ts",
    "test:squadrons-remote": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/squadron-remote-rows.test.ts",
    "test:lan-user-map": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/lan-user-map.test.ts",
    "test:admin-audit-lan": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/admin-audit-lan.test.ts",
    "test:admin-overview-stats": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/admin-overview-pilot-stats.test.ts",
    "test:translations": "tsx --test --test-force-exit tests/translation-coverage.test.ts",
    "test:lan-read-scope": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/lan-read-scope.test.ts",
    "test:lan-read-scope-routes": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/lan-read-scope-routes.test.ts",
    "test:legacy-residue": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/legacy-residue.test.ts",
    "test:calc-snapshot": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/calc-snapshot.test.ts",
    "test:multi-pc-cross": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/multi-pc-cross.test.ts",
    "test:multi-pc-real-process": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit --test-timeout=120000 tests/multi-pc-real-process.test.ts",
    "test:sorties-writes-gate": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/sorties-writes-gate.test.ts",
    "test:install-profile-routes": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/install-profile-routes.test.ts",
    "test:peer-tokens-routes": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/peer-tokens-routes.test.ts",
    "test:peer-tokens-page": "tsx --tsconfig tests/tsconfig.json --import=./tests/peer-tokens-page-register.mjs --test --test-force-exit tests/peer-tokens-page.test.ts",
    "test:aggregate-fanout": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/aggregate-fanout-routes.test.ts",
    "test:ensure-schema": "tsx --tsconfig tests/tsconfig.json --test --test-force-exit tests/ensure-schema-idempotent.test.ts",
    "test:matrix-playwright": "node e2e/matrix/build-dashboard.mjs && playwright test --config playwright.matrix.config.ts",
    "electron:compile": "tsc -p electron/tsconfig.json && node -e \"require('fs').mkdirSync('dist-electron',{recursive:true});require('fs').writeFileSync('dist-electron/package.json',JSON.stringify({type:'commonjs'}))\"",
    "electron:dev": "pnpm run electron:compile && electron dist-electron/main.js",
    "electron:build": "pnpm run build && pnpm run electron:compile && electron-builder --win nsis --config electron-builder.json"
  },
